<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:use-macro="api.macro('kotti:templates/master.pt')">
<head>
    <title metal:fill-slot="title">智能匹配 - AI共创</title>
</head>
<body>
    <div metal:fill-slot="content" class="match-page">
        <div class="container">
            <div class="page-header">
                <h1>智能匹配</h1>
                <p class="lead">通过标签找到最适合的点子和资源</p>
            </div>

            <div class="row">
                <!-- 左侧：标签选择 -->
                <div class="col-md-4">
                    <div class="panel panel-default">
                        <div class="panel-heading">
                            <h3 class="panel-title">选择标签</h3>
                        </div>
                        <div class="panel-body">
                            <div class="form-group">
                                <input type="text" id="tag-input" class="form-control"
                                       placeholder="输入标签后按回车添加">
                            </div>
                            
                            <div id="selected-tags" class="selected-tags">
                                <!-- 选中的标签会显示在这里 -->
                            </div>

                            <div class="match-type">
                                <label>匹配类型：</label>
                                <div class="radio">
                                    <label>
                                        <input type="radio" name="match-type" value="idea" checked>
                                        查找点子
                                    </label>
                                </div>
                                <div class="radio">
                                    <label>
                                        <input type="radio" name="match-type" value="resource">
                                        查找资源
                                    </label>
                                </div>
                            </div>

                            <button class="btn btn-primary btn-block" onclick="MatchUI.doMatch()">
                                开始匹配
                            </button>
                        </div>
                    </div>

                    <div class="panel panel-default">
                        <div class="panel-heading">
                            <h3 class="panel-title">热门标签</h3>
                        </div>
                        <div class="panel-body">
                            <div class="popular-tags">
                                <tal:repeat tal:repeat="tag_count popular_tags">
                                    <span class="tag label label-default"
                                          onclick="MatchUI.addTag('${tag_count[0]}')">
                                        ${tag_count[0]} <span class="count">(${tag_count[1]})</span>
                                    </span>
                                </tal:repeat>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 右侧：匹配结果 -->
                <div class="col-md-8">
                    <div class="panel panel-default">
                        <div class="panel-heading">
                            <h3 class="panel-title">匹配结果</h3>
                        </div>
                        <div class="panel-body">
                            <div id="match-results">
                                <div class="empty-state text-center">
                                    <p class="text-muted">选择标签后点击"开始匹配"查看结果</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .match-page {
            padding: 20px;
        }

        .selected-tags {
            min-height: 50px;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 4px;
            margin-bottom: 15px;
        }

        .selected-tags .tag {
            margin: 3px;
            display: inline-block;
            cursor: pointer;
        }

        .selected-tags .tag:hover {
            opacity: 0.8;
        }

        .popular-tags .tag {
            margin: 3px;
            display: inline-block;
            cursor: pointer;
            transition: all 0.2s;
        }

        .popular-tags .tag:hover {
            background: #667eea;
            color: white;
        }

        .popular-tags .tag .count {
            font-size: 11px;
            opacity: 0.7;
        }

        .match-type {
            margin: 15px 0;
        }

        .result-card {
            border: 1px solid #e9ecef;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
            transition: box-shadow 0.2s;
        }

        .result-card:hover {
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .result-card .match-score {
            font-size: 24px;
            font-weight: bold;
            color: #667eea;
        }

        .result-card .common-tags .tag {
            margin: 2px;
        }

        .empty-state {
            padding: 60px;
            color: #999;
        }

        .loading {
            text-align: center;
            padding: 40px;
        }
    </style>

    <script>
        const MatchUI = {
            selectedTags: [],

            init: function() {
                // 标签输入
                document.getElementById('tag-input').addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        const tag = this.value.trim();
                        if (tag) {
                            MatchUI.addTag(tag);
                            this.value = '';
                        }
                    }
                });
            },

            addTag: function(tag) {
                tag = tag.trim();
                if (!tag || this.selectedTags.includes(tag)) return;
                
                this.selectedTags.push(tag);
                this.renderSelectedTags();
            },

            removeTag: function(tag) {
                this.selectedTags = this.selectedTags.filter(t => t !== tag);
                this.renderSelectedTags();
            },

            renderSelectedTags: function() {
                const container = document.getElementById('selected-tags');
                if (this.selectedTags.length === 0) {
                    container.innerHTML = '<span class="text-muted">点击或输入标签</span>';
                    return;
                }

                container.innerHTML = this.selectedTags.map(tag => 
                    `<span class="tag label label-primary" onclick="MatchUI.removeTag('${tag}')">
                        ${tag} <i class="glyphicon glyphicon-remove"></i>
                    </span>`
                ).join(' ');
            },

            doMatch: async function() {
                if (this.selectedTags.length === 0) {
                    alert('请至少选择一个标签');
                    return;
                }

                const matchType = document.querySelector('input[name="match-type"]:checked').value;
                const resultsDiv = document.getElementById('match-results');
                
                resultsDiv.innerHTML = '<div class="loading"><i class="glyphicon glyphicon-refresh spinning"></i> 正在匹配...</div>';

                try {
                    const response = await fetch('/api/match/by-tags', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            tags: this.selectedTags,
                            type: matchType
                        })
                    });

                    const data = await response.json();
                    
                    if (data.success) {
                        this.renderResults(data.results, matchType);
                    } else {
                        resultsDiv.innerHTML = `<div class="alert alert-danger">${data.error}</div>`;
                    }
                } catch (error) {
                    resultsDiv.innerHTML = `<div class="alert alert-danger">匹配失败: ${error.message}</div>`;
                }
            },

            renderResults: function(results, type) {
                const resultsDiv = document.getElementById('match-results');
                
                if (results.length === 0) {
                    resultsDiv.innerHTML = `
                        <div class="empty-state">
                            <p>没有找到匹配的结果</p>
                            <p class="text-muted">尝试添加更多标签或更换匹配类型</p>
                        </div>
                    `;
                    return;
                }

                const typeLabel = type === 'idea' ? '点子' : '资源';
                
                resultsDiv.innerHTML = `
                    <p class="text-muted">找到 ${results.length} 个匹配的${typeLabel}</p>
                    ${results.map(item => `
                        <div class="result-card">
                            <div class="row">
                                <div class="col-md-9">
                                    <h4><a href="${item.url}">${item.title}</a></h4>
                                    <p>${item.description}...</p>
                                    <div class="common-tags">
                                        <strong>匹配标签：</strong>
                                        ${item.common_tags.map(t => 
                                            `<span class="tag label label-success">${t}</span>`
                                        ).join(' ')}
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <div class="match-score">${item.match_score}%</div>
                                    <small class="text-muted">匹配度</small>
                                </div>
                            </div>
                        </div>
                    `).join('')}
                `;
            }
        };

        // 初始化
        document.addEventListener('DOMContentLoaded', function() {
            MatchUI.init();
            MatchUI.renderSelectedTags();
        });
    </script>
</body>
</html>
