<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:use-macro="api.macro('kotti:templates/master.pt')">
<head>
    <title metal:fill-slot="title">AI 助手 - AI共创</title>
</head>
<body>
    <div metal:fill-slot="content" class="ai-assistant-page">
        <div class="container">
            <div class="page-header">
                <h1>AI 助手</h1>
                <p class="lead">智能辅助，助力点子落地</p>
            </div>

            <div class="row">
                <!-- 左侧：快捷功能 -->
                <div class="col-md-3">
                    <div class="panel panel-default">
                        <div class="panel-heading">
                            <h3 class="panel-title">快捷功能</h3>
                        </div>
                        <div class="panel-body">
                            <div class="quick-actions">
                                <button class="btn btn-default btn-block" onclick="AIAssistantUI.quickAction('optimize')">
                                    💡 优化点子描述
                                </button>
                                <button class="btn btn-default btn-block" onclick="AIAssistantUI.quickAction('tags')">
                                    🏷️ 生成标签建议
                                </button>
                                <button class="btn btn-default btn-block" onclick="AIAssistantUI.quickAction('match')">
                                    🔗 匹配资源推荐
                                </button>
                                <button class="btn btn-default btn-block" onclick="AIAssistantUI.quickAction('brainstorm')">
                                    🧠 头脑风暴
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="panel panel-default">
                        <div class="panel-heading">
                            <h3 class="panel-title">模型选择</h3>
                        </div>
                        <div class="panel-body">
                            <select id="model-select" class="form-control">
                                <option value="gpt-4.1-mini">GPT-4.1 Mini (推荐)</option>
                                <option value="gpt-4.1">GPT-4.1</option>
                                <option value="gpt-4o">GPT-4o</option>
                                <option value="deepseek-v3">DeepSeek V3</option>
                                <option value="claude-3.5-sonnet">Claude 3.5 Sonnet</option>
                                <option value="llama-3.3-70b">Llama 3.3 70B</option>
                            </select>
                            <p class="help-block">
                                <small>所有模型均通过 g4f 在浏览器中直接调用，无需后端</small>
                            </p>
                        </div>
                    </div>

                    <div class="panel panel-default">
                        <div class="panel-heading">
                            <h3 class="panel-title">对话管理</h3>
                        </div>
                        <div class="panel-body">
                            <button class="btn btn-warning btn-block" onclick="AIAssistantUI.clearChat()">
                                🗑️ 清空对话
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 右侧：聊天区域 -->
                <div class="col-md-9">
                    <div class="chat-container">
                        <!-- 聊天消息区域 -->
                        <div id="chat-messages" class="chat-messages">
                            <div class="welcome-message">
                                <h3>👋 欢迎使用 AI 助手</h3>
                                <p>我可以帮助你：</p>
                                <ul>
                                    <li>优化和完善 AI 点子描述</li>
                                    <li>生成合适的标签建议</li>
                                    <li>推荐匹配的资源</li>
                                    <li>进行头脑风暴和创意激发</li>
                                    <li>回答 AI 相关问题</li>
                                </ul>
                                <p class="text-muted">
                                    <small>💡 提示：所有 AI 调用都在你的浏览器中完成，无需担心隐私泄露</small>
                                </p>
                            </div>
                        </div>

                        <!-- 输入区域 -->
                        <div class="chat-input-area">
                            <div class="input-group">
                                <textarea id="chat-input" 
                                          class="form-control" 
                                          placeholder="输入你的问题或需求..."
                                          rows="3"></textarea>
                                <span class="input-group-btn">
                                    <button id="send-btn" 
                                            class="btn btn-primary btn-lg" 
                                            onclick="AIAssistantUI.sendMessage()">
                                        发送
                                    </button>
                                </span>
                            </div>
                            <div class="input-hints">
                                <span class="text-muted">
                                    <small>按 Ctrl+Enter 发送 | 当前模型: <span id="current-model">GPT-4.1 Mini</span></small>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 加载 g4f 客户端和 AI 助手 -->
    <script type="module">
        // 导入 AI 助手类
        import AIAssistant from '/static/js/ai-assistant.js';
        window.aiAssistant = new AIAssistant();
        
        // 初始化
        document.addEventListener('DOMContentLoaded', async () => {
            const initialized = await window.aiAssistant.init();
            if (initialized) {
                console.log('AI Assistant ready');
            }
        });
    </script>

    <style>
        .ai-assistant-page {
            padding: 20px;
            min-height: calc(100vh - 100px);
        }

        .chat-container {
            display: flex;
            flex-direction: column;
            height: calc(100vh - 250px);
            min-height: 500px;
            border: 1px solid #ddd;
            border-radius: 8px;
            background: #f8f9fa;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .welcome-message {
            text-align: center;
            padding: 40px;
            color: #666;
        }

        .welcome-message h3 {
            color: #333;
            margin-bottom: 20px;
        }

        .welcome-message ul {
            text-align: left;
            display: inline-block;
            margin: 20px 0;
        }

        .message {
            margin-bottom: 15px;
            padding: 12px 16px;
            border-radius: 12px;
            max-width: 85%;
            word-wrap: break-word;
        }

        .message.user {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            margin-left: auto;
            border-bottom-right-radius: 4px;
        }

        .message.assistant {
            background: white;
            border: 1px solid #e9ecef;
            border-bottom-left-radius: 4px;
        }

        .message.assistant pre {
            background: #f4f4f4;
            padding: 10px;
            border-radius: 4px;
            overflow-x: auto;
        }

        .message.assistant code {
            background: #f4f4f4;
            padding: 2px 6px;
            border-radius: 3px;
        }

        .chat-input-area {
            padding: 15px;
            background: white;
            border-top: 1px solid #ddd;
            border-radius: 0 0 8px 8px;
        }

        .chat-input-area textarea {
            resize: none;
            border-radius: 8px;
        }

        .chat-input-area .input-group {
            display: flex;
            align-items: flex-end;
        }

        .chat-input-area .input-group-btn {
            margin-left: 10px;
        }

        .input-hints {
            margin-top: 8px;
        }

        .quick-actions .btn {
            margin-bottom: 10px;
            text-align: left;
        }

        .typing-indicator {
            display: inline-flex;
            align-items: center;
            padding: 12px 16px;
            background: white;
            border-radius: 12px;
            border: 1px solid #e9ecef;
        }

        .typing-indicator span {
            height: 8px;
            width: 8px;
            background: #667eea;
            border-radius: 50%;
            display: inline-block;
            margin: 0 2px;
            animation: typing 1.4s infinite;
        }

        .typing-indicator span:nth-child(2) {
            animation-delay: 0.2s;
        }

        .typing-indicator span:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-10px); }
        }

        .error-message {
            background: #fff3f3;
            border: 1px solid #ffcccc;
            color: #cc0000;
        }
    </style>

    <script>
        // AI 助手 UI 控制器
        const AIAssistantUI = {
            isProcessing: false,

            // 发送消息
            sendMessage: async function() {
                if (this.isProcessing) return;

                const input = document.getElementById('chat-input');
                const message = input.value.trim();
                if (!message) return;

                // 显示用户消息
                this.addMessage('user', message);
                input.value = '';

                // 显示加载状态
                this.isProcessing = true;
                this.showTypingIndicator();

                try {
                    // 调用 AI
                    const modelSelect = document.getElementById('model-select');
                    const result = await window.aiAssistant.chat(message, {
                        model: modelSelect.value
                    });

                    this.hideTypingIndicator();

                    if (result.success) {
                        this.addMessage('assistant', result.content);
                    } else {
                        this.addMessage('assistant', '❌ ' + result.error, 'error');
                    }
                } catch (error) {
                    this.hideTypingIndicator();
                    this.addMessage('assistant', '❌ 发生错误: ' + error.message, 'error');
                }

                this.isProcessing = false;
            },

            // 添加消息
            addMessage: function(role, content, type = 'normal') {
                const container = document.getElementById('chat-messages');
                const messageDiv = document.createElement('div');
                messageDiv.className = `message ${role}${type === 'error' ? ' error-message' : ''}`;
                
                // 简单的 Markdown 渲染
                content = this.renderMarkdown(content);
                messageDiv.innerHTML = content;
                
                container.appendChild(messageDiv);
                container.scrollTop = container.scrollHeight;
            },

            // 简单的 Markdown 渲染
            renderMarkdown: function(text) {
                return text
                    .replace(/```(\w+)?\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>')
                    .replace(/`([^`]+)`/g, '<code>$1</code>')
                    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
                    .replace(/\*([^*]+)\*/g, '<em>$1</em>')
                    .replace(/\n/g, '<br>');
            },

            // 显示打字指示器
            showTypingIndicator: function() {
                const container = document.getElementById('chat-messages');
                const indicator = document.createElement('div');
                indicator.id = 'typing-indicator';
                indicator.className = 'typing-indicator';
                indicator.innerHTML = '<span></span><span></span><span></span>';
                container.appendChild(indicator);
                container.scrollTop = container.scrollHeight;
            },

            // 隐藏打字指示器
            hideTypingIndicator: function() {
                const indicator = document.getElementById('typing-indicator');
                if (indicator) indicator.remove();
            },

            // 快捷功能
            quickAction: function(action) {
                const prompts = {
                    'optimize': '我想优化一个 AI 点子的描述，请告诉我需要提供哪些信息？',
                    'tags': '请帮我为内容生成标签建议，我需要提供什么信息？',
                    'match': '我想找一个适合我点子的资源，应该如何描述我的需求？',
                    'brainstorm': '我想进行 AI 相关的头脑风暴，请给我一些启发性的问题或方向。'
                };
                
                document.getElementById('chat-input').value = prompts[action] || '';
                document.getElementById('chat-input').focus();
            },

            // 清空对话
            clearChat: function() {
                if (confirm('确定要清空所有对话吗？')) {
                    window.aiAssistant.clearHistory();
                    const container = document.getElementById('chat-messages');
                    container.innerHTML = `
                        <div class="welcome-message">
                            <h3>👋 欢迎使用 AI 助手</h3>
                            <p>对话已清空，有什么可以帮助你的吗？</p>
                        </div>
                    `;
                }
            }
        };

        // 快捷键支持
        document.getElementById('chat-input').addEventListener('keydown', function(e) {
            if (e.ctrlKey && e.key === 'Enter') {
                AIAssistantUI.sendMessage();
            }
        });

        // 模型切换
        document.getElementById('model-select').addEventListener('change', function() {
            const modelName = this.options[this.selectedIndex].text;
            document.getElementById('current-model').textContent = modelName;
            window.aiAssistant.setModel(this.value);
        });
    </script>
</body>
</html>
