<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:use-macro="api.macro('kotti:templates/master.pt')">
<head>
    <title metal:fill-slot="title">分享资源 - AI共创</title>
</head>
<body>
    <div metal:fill-slot="content" class="resource-add-page">
        <div class="page-header">
            <h1>分享资源</h1>
            <p class="lead">分享 AI 资源，帮助点子落地</p>
        </div>

        <form method="POST" class="form-horizontal">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">基本信息</h3>
                </div>
                <div class="panel-body">
                    <div class="form-group">
                        <label class="col-md-2 control-label">标题 *</label>
                        <div class="col-md-10">
                            <input type="text" name="title" class="form-control" required
                                   placeholder="资源名称">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-2 control-label">分类 *</label>
                        <div class="col-md-10">
                            <select name="category" class="form-control" required>
                                <tal:loop tal:repeat="cat categories">
                                    <option value="${cat}">${categories[cat]}</option>
                                </tal:loop>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-2 control-label">访问方式</label>
                        <div class="col-md-10">
                            <select name="access_type" class="form-control">
                                <tal:loop tal:repeat="acc access_types">
                                    <option value="${acc}">${access_types[acc]}</option>
                                </tal:loop>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-2 control-label">资源链接</label>
                        <div class="col-md-10">
                            <input type="url" name="url" class="form-control"
                                   placeholder="https://...">
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">详细描述</h3>
                </div>
                <div class="panel-body">
                    <div class="form-group">
                        <label class="col-md-2 control-label">资源描述 *</label>
                        <div class="col-md-10">
                            <textarea name="description" class="form-control" rows="6" required
                                      placeholder="详细描述这个资源的特点、用途、优势等"></textarea>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-2 control-label">使用说明</label>
                        <div class="col-md-10">
                            <textarea name="usage_guide" class="form-control" rows="4"
                                      placeholder="如何使用这个资源"></textarea>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-2 control-label">限制条件</label>
                        <div class="col-md-10">
                            <textarea name="limitations" class="form-control" rows="4"
                                      placeholder="使用限制、注意事项等"></textarea>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-2 control-label">标签</label>
                        <div class="col-md-10">
                            <input type="text" name="tags" class="form-control"
                                   placeholder="用逗号分隔多个标签，如：开源, 免费, API">
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <button type="submit" class="btn btn-primary btn-lg">分享资源</button>
                    <a href="${request.application_url}/resources" class="btn btn-default btn-lg">取消</a>
                </div>
            </div>
        </form>
    </div>
</body>
</html>
